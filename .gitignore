# ===========================================================================
# Python
# ===========================================================================

__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
dist/
build/

# Virtual environments (uv creates .venv in the project directory)
.venv/
venv/
api/.venv/
pyvenv.cfg

# uv
# uv.lock is intentionally tracked — do NOT add it here
.python-version

# Type checkers / linters
.mypy_cache/
.ruff_cache/

# Test artefacts
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ===========================================================================
# Django
# ===========================================================================

# SQLite (dev fallback only — PostgreSQL is the real target)
*.db
*.sqlite3

# Collected static files — generated by `collectstatic` at build time
staticfiles/

# Uploaded media — stored in S3 in production, locally in development
media/
mediafiles/

# Local settings overrides — never commit credentials
config/settings/local.py

# Celery Beat persistent schedule and PID files
# These are runtime artefacts written by `celery beat` to the working directory
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid

# ===========================================================================
# Node / Next.js / Bun
# ===========================================================================

node_modules/
.next/
out/
/build

# TypeScript incremental compilation cache
*.tsbuildinfo

# Next.js auto-generated type declarations
next-env.d.ts

# Vercel local deployment artefacts
.vercel/

# Bun
# bun.lock is intentionally tracked — do NOT add it here
bun.lockb

# Test coverage
coverage/

# Debug logs
yarn-debug.log*
yarn-error.log*

# ===========================================================================
# Environment / secrets
# ===========================================================================

.env
.env.*
# Allow example files — commit these as templates so developers know what to fill in
!.env.example
!.env.*.example

# Docker development environment files — populated locally, never committed
.docker/development/api/.env
.docker/development/.env
.docker/staging/.env

# PEM keys and certificates
*.pem
*.key
*.p12

# ===========================================================================
# Terraform
# ===========================================================================

# Provider plugin cache — large binaries, downloaded by `terraform init`
**/.terraform/

# .terraform.lock.hcl is intentionally NOT listed here.
# It must be committed — it pins provider versions the same way
# bun.lock pins bun packages.

# Variable files often contain secrets (API keys, passwords, IPs)
**/*.tfvars
**/*.tfvars.json

# State files contain resource IDs and may contain secrets
*.tfstate
*.tfstate.*
*.tfstate.d/

# Plan files (binary output of `terraform plan`)
**/*.tfplan
**/tfplan

# ===========================================================================
# Redis
# ===========================================================================

# Redis persistence dump files
*.rdb

# ===========================================================================
# Logs
# ===========================================================================

*.log
logs/

# ===========================================================================
# OS
# ===========================================================================

.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# ===========================================================================
# IDE
# ===========================================================================

# VS Code — ignore user-specific files but track shared team settings.
# settings.json and extensions.json are committed so every developer gets
# the same formatter (Ruff + Biome) and extension recommendations on first open.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

.idea/
*.swp
*.swo
*~

# Cursor IDE project settings — keep out of the repo
.cursor/

# ===========================================================================
# Deployment
# ===========================================================================

# Deployment SSH key config (ad-hoc scripts, known_hosts overrides, etc.)
.deploy/

# Local ops script config — contains EC2_HOST and EC2_SSH_KEY (never commit)
scripts/.scripts.env

# Database backups
db_backup/
