# .scripts.env — local configuration for ops scripts.
#
# Copy this file to scripts/.scripts.env and fill in the values.
# This file is gitignored — never commit .scripts.env.
#
# The scripts (_common.sh) load this file automatically when present.
# Values here are overridden by environment variables of the same name.
#
# ---------------------------------------------------------------------------
# EC2 connection
# ---------------------------------------------------------------------------

# Public Elastic IP of the EC2 instance.
#
# How to find it:
#   (a) Terraform output (if you provisioned this machine):
#         cd .terraform && terraform output ec2_public_ip
#
#   (b) AWS console: EC2 → Elastic IPs → filter by project tag
#
#   (c) AWS CLI:
#         aws ec2 describe-addresses \
#           --query "Addresses[?Tags[?Key=='Project' && Value=='myproject']].PublicIp" \
#           --output text
#
#   (d) GitHub Actions secret EC2_HOST (set when CI was configured)
#
EC2_HOST=

# Path to the private SSH key file on this machine.
#
# This is the private key whose PUBLIC half was passed to Terraform as
# var.ssh_public_key during infrastructure provisioning.
#
# How to obtain the private key on a new machine:
#   (a) Your password manager (1Password, Bitwarden, etc.) — recommended.
#       Store the private key as a secure note and copy it to ~/.ssh/.
#
#   (b) AWS Secrets Manager (if your team stores it there):
#         aws secretsmanager get-secret-value \
#           --secret-id myproject/ec2-ssh-key \
#           --query SecretString --output text > ~/.ssh/myproject-ec2
#         chmod 600 ~/.ssh/myproject-ec2
#
#   (c) AWS SSM Parameter Store:
#         aws ssm get-parameter \
#           --name /myproject/ec2-ssh-key \
#           --with-decryption \
#           --query Parameter.Value --output text > ~/.ssh/myproject-ec2
#         chmod 600 ~/.ssh/myproject-ec2
#
# Recommended filename convention: ~/.ssh/<project_name>-ec2
# The scripts check this location automatically when EC2_SSH_KEY is not set.
#
EC2_SSH_KEY=~/.ssh/myproject-ec2

# ---------------------------------------------------------------------------
# Optional overrides
# ---------------------------------------------------------------------------

# SSH login user. Default: ec2-user (Amazon Linux 2023).
# EC2_USER=ec2-user

# Absolute path to the project on the EC2 instance. Default: /opt/myproject.
# REMOTE_PROJECT_DIR=/opt/myproject

# Docker Compose project name. Default: myproject-prod (from compose `name:` field).
# Used to construct container names for docker inspect.
# COMPOSE_PROJECT=myproject-prod
